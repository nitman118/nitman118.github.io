---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About — Nitish Singh"
  description="Experience, education, and skills of Nitish Singh — Data Scientist at KMWE and part-time Assistant Professor at TU/e."
>
  <main class="container" style="padding-top: 2.5rem;">
    <div class="row g-4">
      <!-- LEFT: profile sidebar -->
      <div class="col-lg-4">
        <div class="profile-card">
          <h3>Contact</h3>
          <div class="meta-line"><i class="fa-solid fa-briefcase"></i> Data Scientist · Asst. Professor</div>
          <div class="meta-line"><i class="fa-solid fa-location-dot"></i> Eindhoven, Netherlands</div>
          <div class="meta-line">
            <i class="fa-solid fa-envelope"></i>
            <a href="mailto:singhnitish.work@gmail.com">singhnitish.work@gmail.com</a>
          </div>
          <div class="meta-line">
            <i class="fa-solid fa-globe"></i>
            <a href="https://www.nitishsingh.com" target="_blank" rel="noopener">www.nitishsingh.com</a>
          </div>

          <hr />
          <h3>Research interests</h3>
          <div class="tag-list">
            <span class="tag">Simulation modelling</span>
            <span class="tag">Digital twins</span>
            <span class="tag">Deep reinforcement learning</span>
            <span class="tag">Quantitative methods</span>
            <span class="tag">Process mining</span>
            <span class="tag">Unified Namespace</span>
            <span class="tag">Agentic AI</span>
          </div>

          <hr />
          <h3>Tools</h3>
          <div class="tag-list">
            <span class="tag tag-muted">Python</span>
            <span class="tag tag-muted">PyTorch</span>
            <span class="tag tag-muted">AnyLogic</span>
            <span class="tag tag-muted">SimPy</span>
            <span class="tag tag-muted">Plant Simulation</span>
            <span class="tag tag-muted">Gurobi</span>
            <span class="tag tag-muted">SQL</span>
            <span class="tag tag-muted">Java</span>
            <span class="tag tag-muted">React</span>
            <span class="tag tag-muted">Power BI</span>
          </div>

          <hr />
          <h3>Certifications</h3>
          <div class="tag-list">
            <span class="tag tag-muted">Lean Six Sigma · Black Belt</span>
          </div>

          <hr />
          <h3>Languages</h3>
          <div class="meta-line">
            English
            <span class="ms-auto" style="color:var(--text-muted); font-size:0.85rem;">Fluent</span>
          </div>
          <div class="meta-line">
            Dutch
            <span class="ms-auto" style="color:var(--text-muted); font-size:0.85rem;">Conversational</span>
          </div>
          <div class="meta-line">
            Hindi
            <span class="ms-auto" style="color:var(--text-muted); font-size:0.85rem;">Native</span>
          </div>
        </div>
      </div>

      <!-- RIGHT: experience + education -->
      <div class="col-lg-8">
        <!-- Experience -->
        <div class="timeline-card">
          <h2><i class="fa-solid fa-suitcase"></i> Experience</h2>

          <div class="exp-item">
            <div class="role">Assistant Professor (Part-time)</div>
            <div class="org">Eindhoven University of Technology · AIMM, EAISI</div>
            <div class="meta">
              <span><i class="fa-regular fa-calendar"></i>Oct 2025 – Present</span>
              <span><i class="fa-solid fa-location-dot"></i>Eindhoven, NL</span>
              <span class="badge-current">Current</span>
            </div>
            <p>
              Research on intelligent and interoperable shopfloors: semantic interoperability through
              Unified Namespace architectures and agentic AI for adaptive production. Affiliated with
              the AI-Enabled Manufacturing & Maintenance group at the Eindhoven AI Systems Institute.
            </p>
          </div>

          <div class="exp-item">
            <div class="role">Data Scientist</div>
            <div class="org">KMWE · Brainport Industries Campus</div>
            <div class="meta">
              <span><i class="fa-regular fa-calendar"></i>Aug 2024 – Present</span>
              <span><i class="fa-solid fa-location-dot"></i>Eindhoven, NL</span>
              <span class="badge-current">Current</span>
            </div>
            <p>
              Designing and developing digital platforms, AI agents, and Power BI dashboards for
              production; integrating data across ERP, MES, and shopfloor systems. Collaborating with
              production, CAM, and IT stakeholders to drive Industry 4.0 adoption — including
              next-generation equipment selection, layout, and process planning.
            </p>
          </div>

          <div class="exp-item">
            <div class="role">Industry Process Consultant</div>
            <div class="org">Dassault Systèmes · DELMIA Quintiq</div>
            <div class="meta">
              <span><i class="fa-regular fa-calendar"></i>Mar 2024 – Jul 2024</span>
              <span><i class="fa-solid fa-location-dot"></i>'s-Hertogenbosch, NL</span>
            </div>
            <p>Supply-chain planning and scheduling consulting in the DELMIA Quintiq team.</p>
          </div>

          <div class="exp-item">
            <div class="role">PhD Researcher · Advanced Manufacturing Logistics</div>
            <div class="org">Eindhoven University of Technology · Brainport Industries Campus</div>
            <div class="meta">
              <span><i class="fa-regular fa-calendar"></i>Sep 2019 – May 2025</span>
              <span><i class="fa-solid fa-location-dot"></i>Eindhoven, NL</span>
            </div>
            <p>
              New manufacturing layout evaluation using AnyLogic discrete-event simulation.
              Development of dispatching algorithms for self-guided vehicles using metaheuristics
              and reinforcement learning in Python. Led data-analytics projects with VDL Group,
              Schenker Logistics, Rockwool, and Van der Wal.
            </p>
          </div>

          <div class="exp-item">
            <div class="role">Researcher</div>
            <div class="org">KMWE & Ijssel Technologies</div>
            <div class="meta">
              <span><i class="fa-regular fa-calendar"></i>Nov 2017 – Aug 2019</span>
              <span><i class="fa-solid fa-location-dot"></i>Eindhoven, NL</span>
            </div>
            <p>
              Created digital twins and simulation models for facility redesign at KMWE during the
              relocation to Brainport Industries Campus. Developed customised AGV fleet-control
              algorithms at Ijssel Technologies.
            </p>
          </div>

          <div class="exp-item">
            <div class="role">Senior IT Consultant</div>
            <div class="org">Schneider Electric · Global Delivery IT</div>
            <div class="meta">
              <span><i class="fa-regular fa-calendar"></i>Jul 2014 – Aug 2017</span>
              <span><i class="fa-solid fa-location-dot"></i>Bangalore, India</span>
            </div>
            <p>
              Managed Agile SAP GRC (governance, risk, compliance) implementation projects on-site
              in Brazil and China. Automated manual data uploads in SAP ECC and supported
              segregation-of-duties and fraud-management initiatives.
            </p>
          </div>
        </div>

        <!-- Education -->
        <div class="timeline-card">
          <h2><i class="fa-solid fa-graduation-cap"></i> Education</h2>

          <div class="exp-item">
            <div class="role">PhD in Industrial Engineering</div>
            <div class="org">Eindhoven University of Technology · IE & IS</div>
            <div class="meta">
              <span><i class="fa-regular fa-calendar"></i>Sep 2019 – May 2025</span>
              <span><i class="fa-solid fa-location-dot"></i>Eindhoven, NL</span>
            </div>
            <p>
              Part of the Advanced Manufacturing Logistics program at Brainport Industries Campus.
              Thesis on simulation- and AI-based dispatching and scheduling of heterogeneous AGV
              fleets in high-mix, low-volume manufacturing.
            </p>
          </div>

          <div class="exp-item">
            <div class="role">M.Sc. in Operations Management & Logistics</div>
            <div class="org">Eindhoven University of Technology</div>
            <div class="meta">
              <span><i class="fa-regular fa-calendar"></i>Sep 2017 – Aug 2019</span>
              <span><i class="fa-solid fa-location-dot"></i>Eindhoven, NL</span>
            </div>
            <p>
              Manufacturing Systems Engineering — a programme on the interface of machine technology
              and industrial processes.
            </p>
            <span class="badge-honor"><i class="fa-solid fa-award me-1"></i>Graduated Cum Laude</span>
          </div>

          <div class="exp-item">
            <div class="role">B.Tech. in Mechanical & Industrial Engineering</div>
            <div class="org">VIT University, India</div>
            <div class="meta">
              <span><i class="fa-regular fa-calendar"></i>Jul 2010 – May 2014</span>
              <span><i class="fa-solid fa-location-dot"></i>Vellore, India</span>
            </div>
            <p>
              Head of Design, Team Jaabaz International Baja team — design, analysis and construction
              of an all-terrain vehicle.
            </p>
            <span class="badge-honor"><i class="fa-solid fa-award me-1"></i>Special Student Achiever</span>
          </div>
        </div>

        <!-- Awards -->
        <div class="timeline-card">
          <h2><i class="fa-solid fa-trophy"></i> Awards & honours</h2>
          <ul class="award-list">
            <li>
              <i class="fa-solid fa-medal"></i>
              <div>
                <strong>Best Paper Award · European Journal of Operational Research (2025)</strong>
                <span>For "A Matheuristic for AGV Scheduling with Battery Constraints"</span>
              </div>
            </li>
            <li>
              <i class="fa-solid fa-medal"></i>
              <div>
                <strong>Cum Laude · M.Sc. Operations Management & Logistics</strong>
                <span>Eindhoven University of Technology, 2019</span>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
