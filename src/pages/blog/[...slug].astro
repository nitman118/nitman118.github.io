---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((p) => !p.data.draft)
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });

const shareTitle = encodeURIComponent(post.data.title);
const shareUrl = encodeURIComponent(new URL(`/blog/${post.id}/`, Astro.site).toString());
---

<BaseLayout
  title={`${post.data.title} — Nitish Singh`}
  description={post.data.summary}
  type="article"
  publishedAt={post.data.publishedAt}
  image={post.data.image}
>
  <article class="post-article container">
    <header class="post-header">
      <div class="post-meta">
        <time datetime={post.data.publishedAt.toISOString()}>
          {formatDate(post.data.publishedAt)}
        </time>
        {post.data.readingTime && <span>· {post.data.readingTime} min read</span>}
      </div>
      <h1>{post.data.title}</h1>
      <p class="post-tagline">{post.data.summary}</p>
      {post.data.tags.length > 0 && (
        <div class="tag-list mt-3">
          {post.data.tags.map((tag) => (
            <span class="tag tag-muted">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="post-content">
      <Content />
    </div>

    <footer class="post-footer">
      <a href="/blog">← All notes</a>
      <div>
        Share:
        <a
          href={`https://www.linkedin.com/sharing/share-offsite/?url=${shareUrl}`}
          target="_blank"
          rel="noopener"
          aria-label="Share on LinkedIn"
        >
          <i class="fa-brands fa-linkedin-in"></i>
        </a>
        <a
          href={`https://twitter.com/intent/tweet?text=${shareTitle}&url=${shareUrl}`}
          target="_blank"
          rel="noopener"
          aria-label="Share on X"
          style="margin-left: 0.6rem;"
        >
          <i class="fa-brands fa-x-twitter"></i>
        </a>
      </div>
    </footer>
  </article>
</BaseLayout>
