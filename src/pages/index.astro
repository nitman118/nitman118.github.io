---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 3);

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout
  title="Nitish Singh — Data Scientist & Asst. Professor"
  description="Data Scientist at KMWE and part-time Assistant Professor at Eindhoven University of Technology. Writing about simulation, digital twins, and AI for manufacturing."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Nitish Singh',
    url: 'https://www.nitishsingh.com',
    image: 'https://www.nitishsingh.com/assets/images/me-prof-sq.jpeg',
    jobTitle: 'Data Scientist · Assistant Professor (Part-time)',
    worksFor: [
      { '@type': 'Organization', name: 'KMWE' },
      { '@type': 'CollegeOrUniversity', name: 'Eindhoven University of Technology' },
    ],
    alumniOf: { '@type': 'CollegeOrUniversity', name: 'Eindhoven University of Technology' },
    sameAs: [
      'https://www.linkedin.com/in/nitish-singh/',
      'https://github.com/nitman118',
    ],
    description: 'Researcher and practitioner at the intersection of simulation, digital twins, and AI for manufacturing.',
  })} />
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="row align-items-center g-5">
        <div class="col-lg-7 order-lg-1 order-2">
          <div class="eyebrow">Data Scientist · Assistant Professor</div>
          <h1>Hi, I'm Nitish.<br />I build simulations, digital twins, and AI for manufacturing.</h1>
          <p class="lead">
            Data Scientist at KMWE and part-time Assistant Professor at Eindhoven University of
            Technology. I work at the intersection of operations research, simulation, and machine
            learning — turning shopfloor data into decisions.
          </p>
          <div class="hero-actions">
            <a href="/about" class="btn-primary-clean">
              <i class="fa-solid fa-user"></i> About me
            </a>
            <a href="/blog" class="btn-secondary-clean">
              <i class="fa-solid fa-pen-nib"></i> Read the notes
            </a>
          </div>
        </div>
        <div class="col-lg-5 order-lg-2 order-1 text-center">
          <img src="/assets/images/me-prof-sq.jpeg" class="profile" alt="Nitish Singh" />
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about">
    <div class="container">
      <div class="about-grid">
        <div>
          <img src="/assets/images/Picture3.png" alt="" />
        </div>
        <div>
          <div class="section-eyebrow">About</div>
          <h2>Bridging research and the shopfloor</h2>
          <p>
            I recently completed my PhD in Industrial Engineering at TU/e, where I worked on
            dispatching and scheduling algorithms for autonomous fleets in high-mix, low-volume
            manufacturing.
          </p>
          <p>
            Today I split my time between two roles: as a Data Scientist at KMWE I build digital
            platforms, AI agents, and analytics tooling for daily production; as a part-time
            Assistant Professor in the AIMM group at EAISI, I research intelligent and
            interoperable shopfloors — Unified Namespace architectures and agentic AI for adaptive
            production.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CURRENT ROLES -->
  <section id="now">
    <div class="container">
      <div class="section-eyebrow">What I'm doing now</div>
      <h2>Current roles</h2>
      <div class="role-grid">
        <div class="role-card">
          <div class="role-icon"><i class="fa-solid fa-graduation-cap"></i></div>
          <div class="role-title">Assistant Professor (Part-time)</div>
          <div class="role-org">Eindhoven University of Technology</div>
          <div class="role-meta">
            <i class="fa-regular fa-calendar"></i> Oct 2025 – present · Eindhoven, NL
          </div>
          <p>
            Research in the AIMM (AI-Enabled Manufacturing & Maintenance) group at EAISI on
            intelligent, interoperable shopfloors — Unified Namespace and agentic AI for adaptive
            production.
          </p>
        </div>
        <div class="role-card">
          <div class="role-icon"><i class="fa-solid fa-industry"></i></div>
          <div class="role-title">Data Scientist</div>
          <div class="role-org">KMWE, Brainport Industries Campus</div>
          <div class="role-meta">
            <i class="fa-regular fa-calendar"></i> Aug 2024 – present · Eindhoven, NL
          </div>
          <p>
            Designing digital platforms, AI agents, and Power BI dashboards for production.
            Integrating data across ERP, MES, and shopfloor systems to drive Industry 4.0 adoption.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- LATEST NOTES -->
  {posts.length > 0 && (
    <section id="latest-notes">
      <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-2">
          <div>
            <div class="section-eyebrow">Latest notes</div>
            <h2 class="mb-0">Writing</h2>
          </div>
          <a href="/blog" class="btn-secondary-clean">
            All notes <i class="fa-solid fa-arrow-right"></i>
          </a>
        </div>
        <ul class="post-list">
          {posts.map((post) => (
            <li>
              <a class="post-link" href={`/blog/${post.id}/`}>
                <div class="post-meta">
                  <time datetime={post.data.publishedAt.toISOString()}>
                    {formatDate(post.data.publishedAt)}
                  </time>
                  {post.data.readingTime && <span>· {post.data.readingTime} min read</span>}
                </div>
                <h3 class="post-title">{post.data.title}</h3>
                <p class="post-summary">{post.data.summary}</p>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- RESEARCH INTERESTS -->
  <section id="interests">
    <div class="container">
      <div class="row g-4">
        <div class="col-lg-6">
          <div class="section-eyebrow">Research interests</div>
          <h2>What I work on</h2>
          <div class="tag-list mb-3">
            <span class="tag">Simulation modelling</span>
            <span class="tag">Digital twins</span>
            <span class="tag">Deep reinforcement learning</span>
            <span class="tag">Quantitative methods</span>
            <span class="tag">Process mining</span>
            <span class="tag">Unified Namespace</span>
            <span class="tag">Agentic AI</span>
            <span class="tag">Lean Six Sigma (Black Belt)</span>
          </div>
        </div>
        <div class="col-lg-6">
          <div class="section-eyebrow">Tools & technologies</div>
          <h2>Day-to-day stack</h2>
          <div class="tag-list">
            <span class="tag tag-muted">Python</span>
            <span class="tag tag-muted">PyTorch</span>
            <span class="tag tag-muted">AnyLogic</span>
            <span class="tag tag-muted">SimPy</span>
            <span class="tag tag-muted">Plant Simulation</span>
            <span class="tag tag-muted">Gurobi</span>
            <span class="tag tag-muted">SQL</span>
            <span class="tag tag-muted">Java</span>
            <span class="tag tag-muted">React</span>
            <span class="tag tag-muted">Power BI</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
